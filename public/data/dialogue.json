    "id": "level1_intro_response",
    "speaker": "Hero",
    "portraitMood": "neutral",
    "background": "assets/backgrounds/bg_cutscene_default.png",
    "battlefieldState": "idle",
    "lines": [
      "It feels harmless at first.",
      "That is the design."
    ]
  },
  {
    "id": "level1_miniboss_intro",
    "speaker": "DOGE Protocol",
    "portrait": "doge",
    "portraitMood": "smirk",
    "background": "assets/backgrounds/bg_cutscene_default.png",
    "battlefieldState": "idle",
    "lines": [
      "First time here?",
      "Do not worry. You are early.",
      "You always are."
