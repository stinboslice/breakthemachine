    "speaker": "Hero",
    "portraitMood": "neutral",
    "background": "assets/backgrounds/bg_cutscene_default.png",
    "battlefieldState": "idle",
    "lines": [
      "The machine rewards people just enough to keep them exposed.",
      "That is why they stay."
    ]
  },
