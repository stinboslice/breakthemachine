    "speaker": "Hero",
    "portraitMood": "neutral",
    "background": "assets/backgrounds/bg_cutscene_default.png",
    "battlefieldState": "idle",
    "lines": [
      "The system only works if people confuse movement with value.",
      "Most never notice the difference."
    ]
  },
  {
