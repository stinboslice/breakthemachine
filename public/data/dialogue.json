    "speaker": "Narration",
    "portrait": "narrator",
    "portraitMood": "neutral",
    "background": "assets/backgrounds/bg_cutscene_default.png",
    "battlefieldState": "idle",
    "lines": [
      "It starts small.",
      "Low stakes. Low resistance. Easy wins.",
      "That is how they onboard you."
    ]
