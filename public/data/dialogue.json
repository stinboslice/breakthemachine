    "id": "level2_miniboss_intro",
    "speaker": "DOGE Protocol",
    "portrait": "doge",
    "portraitMood": "smirk",
    "background": "assets/backgrounds/bg_cutscene_default.png",
    "battlefieldState": "idle",
    "lines": [
      "Look at you.",
