    "speaker": "Hero",
    "portraitMood": "surprised",
    "background": "assets/backgrounds/bg_cutscene_default.png",
    "battlefieldState": "idle",
    "lines": [
      "The volatility is intentional.",
      "Emotion is part of the architecture."
    ]
