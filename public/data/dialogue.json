    "speaker": "Hero",
    "portraitMood": "neutral",
    "background": "assets/backgrounds/bg_cutscene_default.png",
    "battlefieldState": "idle",
    "lines": [
      "People defended the system because they thought they belonged to it.",
      "They never realized they were feeding it."
    ]
  },
